# Telegram 通知配置
# 1) 在 Telegram 与 @BotFather 对话创建 bot，拿到 token 填到 TELEGRAM_BOT_TOKEN
# 2) 把 bot 加进目标群/频道后，调用 getUpdates 或与 @userinfobot 对话拿到 chat_id
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# 可选：SOCKS5 / HTTP 代理（国内网络通常需要），不用留空
# 示例：socks5://127.0.0.1:1080  或  http://127.0.0.1:7890
TELEGRAM_PROXY=
